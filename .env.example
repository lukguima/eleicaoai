# ============================================================
# EleiçãoAI — Variáveis de Ambiente
# Copie para .env.local e preencha com seus valores reais.
# NUNCA commite o .env.local no repositório.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Chave pública (anon) — segura para o browser; RLS é o controle real
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Chave service_role — PRIVADA, apenas no servidor. NUNCA no frontend.
# Bypassa o RLS — use somente em API routes e workers.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── App ───────────────────────────────────────────────────────
# URL pública da aplicação (usada para construir callbackUrls)
NEXT_PUBLIC_APP_URL=https://eleicaoai.com.br

# ── Suno API (sunoapi.org) ────────────────────────────────────
# Obtenha em: https://sunoapi.org/api-key
SUNO_API_KEY=sua_chave_aqui

# ── OpenAI (DALL-E 3 + GPT-4o Vision) ───────────────────────
# Obtenha em: https://platform.openai.com/api-keys
# Usado para: geração de imagens (DALL-E 3) e análise visual (GPT-4o mini)
# Prioridade 1 no pipeline. Se ausente, cai para Google Imagen ou OpenRouter.
OPENAI_API_KEY=sk-...

# ── Google AI (Imagen 4) ─────────────────────────────────────
# Obtenha em: https://aistudio.google.com/app/apikey
# Prioridade 2 no pipeline (fallback do OpenAI).
GOOGLE_AI_API_KEY=sua_chave_aqui

# ── Mercado Pago ──────────────────────────────────────────────
# Obtenha em: https://www.mercadopago.com.br/developers
# Sem esta variável o sistema usa modo dev (skip_payment: true).
# Token de TESTE começa com "TEST-" (checkout sandbox);
# token de produção começa com "APP_USR-".
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...

# Segredo da assinatura do webhook (painel MP → Webhooks → chave secreta).
# Obrigatório: sem ele, o webhook rejeita todas as notificações (falha fechada).
MERCADOPAGO_WEBHOOK_SECRET=sua_chave_secreta_do_webhook

# Bypass de pagamento para desenvolvimento/staging (NUNCA em produção).
# Quando 'true', a geração é liberada sem exigir pagamento/entitlement.
STAGE_BYPASS_PAYMENT=false

# ── Criptografia de CPF (AES-256) ────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NUNCA perca essa chave — CPFs ficam irrecuperáveis sem ela.
CPF_ENCRYPTION_KEY=64_chars_hex_aqui
